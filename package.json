{
  "name": "dwoj",
  "version": "1.0.0",
  "main": "dist/app.js",
  "bin": {
    "dwoj": "./dist/dwoj-cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/app.js",
    "dev": "tsc && node dist/app.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:delete": "pm2 delete ecosystem.config.js",
    "pm2:logs": "pm2 logs dwoj",
    "pm2:monit": "pm2 monit",
    "pm2:status": "pm2 status dwoj",
    "deploy:build": "npm run build && npm run pm2:restart",
    "deploy:prod": "npm run build && pm2 start ecosystem.config.js --env production",
    "deploy:quick": "npm run build && pm2 start ecosystem.config.js && pm2 save"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "axios": "^1.13.2",
    "body-parser": "^1.20.3",
    "cookie-parser": "^1.4.7",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "fs-extra": "^11.3.2",
    "jsonwebtoken": "^9.0.3",
    "markdown-it": "^14.1.0",
    "multer": "^2.0.2",
    "sqlite3": "^5.1.7",
    "tar": "^7.5.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/markdown-it": "^14.1.2",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/tar": "^6.1.13",
    "typescript": "^6.0.2",
    "pm2": "^5.4.0"
  }
}
